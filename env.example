"""
FinQueryFlow - ETL Processor (Kafka Consumer)
Consumes raw-news topic → Cleans → Chunks → Embeds → Stores in ChromaDB + PostgreSQL
"""

import json
import asyncio
import hashlib
from datetime import datetime
from kafka import KafkaConsumer
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain_openai import OpenAIEmbeddings
import chromadb
from chromadb.config import Settings
import psycopg2
from psycopg2.extras import execute_values
import os
import re

KAFKA_BROKER = os.getenv("KAFKA_BROKER", "localhost:9092")
OPENAI_KEY   = os.getenv("OPENAI_API_KEY", "YOUR_KEY")
CHROMA_HOST  = os.getenv("CHROMA_HOST",  "localhost")
CHROMA_PORT  = int(os.getenv("CHROMA_PORT", "8001"))
PG_DSN       = os.getenv("DATABASE_URL",  "postgresql://user:pass@localhost:5432/finqueryflow")

# ----- Cleaning Helpers -----

def clean_text(text: str) -> str:
    """Strip HTML tags, normalize whitespace, remove boilerplate."""
    text = re.sub(r"<[^>]+>", " ", text)
    text = re.sub(r"\[.*?chars\]", "", text)           # NewsAPI truncation marker
    text = re.sub(r"http\S+", "", text)                 # Remove URLs
    text = re.sub(r"\s+", " ", text).strip()
    return text


def deduplicate_id(article: dict) -> str:
    """Create a stable hash-based ID for deduplication."""
    key = f"{article['ticker']}|{article['title']}|{article['published_at']}"
    return hashlib.md5(key.encode()).hexdigest()


# ----- Chunking -----

splitter = RecursiveCharacterTextSplitter(
    chunk_size=512,
    chunk_overlap=64,
    separators=["\n\n", "\n", ". ", " ", ""],
)


def chunk_article(article: dict) -> list[dict]:
    """Split article into overlapping chunks for dense retrieval."""
    full_text = f"{article['title']}. {article['description']} {article['content']}"
    full_text = clean_text(full_text)
    chunks = splitter.split_text(full_text)
    return [
        {
            "id":           f"{article['_id']}_{i}",
            "text":         chunk,
            "ticker":       article["ticker"],
            "source":       article["source"],
            "url":          article["url"],
            "published_at": article["published_at"],
        }
        for i, chunk in enumerate(chunks)
        if len(chunk.strip()) > 40  # skip tiny fragments
    ]


# ----- Vector Store -----

def get_chroma_collection():
    client = chromadb.HttpClient(
        host=CHROMA_HOST, port=CHROMA_PORT,
        settings=Settings(anonymized_telemetry=False),
    )
    return client.get_or_create_collection(
        name="stock_news",
        metadata={"hnsw:space": "cosine"},
    )


embedder = OpenAIEmbeddings(model="text-embedding-3-small", openai_api_key=OPENAI_KEY)


def upsert_to_chroma(collection, chunks: list[dict]):
    """Batch embed and upsert chunks to ChromaDB."""
    texts = [c["text"] for c in chunks]
    vectors = embedder.embed_documents(texts)
    collection.upsert(
        ids        =[c["id"] for c in chunks],
        embeddings =vectors,
        documents  =texts,
        metadatas  =[{
            "ticker":       c["ticker"],
            "source":       c["source"],
            "url":          c["url"],
            "published_at": c["published_at"],
        } for c in chunks],
    )


# ----- Relational Store -----

def save_to_postgres(article: dict):
    """Persist cleaned article metadata to PostgreSQL."""
    conn = psycopg2.connect(PG_DSN)
    with conn, conn.cursor() as cur:
        cur.execute("""
            INSERT INTO articles (id, ticker, source, title, url, published_at, ingested_at)
            VALUES (%s, %s, %s, %s, %s, %s, %s)
            ON CONFLICT (id) DO NOTHING
        """, (
            article["_id"],
            article["ticker"],
            article["source"],
            article["title"][:500],
            article["url"],
            article["published_at"],
            datetime.utcnow().isoformat(),
        ))
    conn.close()


# ----- Main Consumer Loop -----

def run_etl():
    consumer = KafkaConsumer(
        "raw-news",
        bootstrap_servers=KAFKA_BROKER,
        value_deserializer=lambda m: json.loads(m.decode("utf-8")),
        group_id="etl-processor",
        auto_offset_reset="latest",
        enable_auto_commit=True,
    )
    collection = get_chroma_collection()
    print("[ETL] Consumer started. Waiting for messages...")

    for msg in consumer:
        article = msg.value
        article["_id"] = deduplicate_id(article)
        try:
            chunks = chunk_article(article)
            if chunks:
                upsert_to_chroma(collection, chunks)
                save_to_postgres(article)
                print(f"[ETL] {article['ticker']} | {len(chunks)} chunks | {article['source']}")
        except Exception as e:
            print(f"[ETL] Error processing article: {e}")


if __name__ == "__main__":
    run_etl()
